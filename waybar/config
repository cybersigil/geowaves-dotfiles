{
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-left": 15,
    "margin-right": 15,
    "spacing": 15,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["idle_inhibitor", "clock", "custom/weather"], 
    "modules-right": ["memory", "backlight", "custom/updates", "network", "pulseaudio", "battery", "custom/hostname", "tray"],

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰅶",
            "deactivated": "󰾪"
        }
    },

    "memory": {
        "interval": 30,
        "format": "󰍛 {used:0.1f}G",
        "tooltip-format": "{used:0.1f}G/{total:0.1f}G"
    },

    "backlight": {
        "device": "intel_backlight", 
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },

    "custom/weather": {
        "format": "{} ",
        "tooltip": true,
        "interval": 3600,
        "exec": "curl -s 'wttr.in/?format=%c%t' | tr -d ' '",
        "return-type": ""
},


    "custom/updates": {
        "format": "󰚰 {}",
        "interval": 7200,                     
        "exec": "checkupdates | wc -l",       
        "exit-code": 0
    },

    "custom/hostname": {
        "format": "󰣇 {}",
        "exec": "hostname"
    }
}