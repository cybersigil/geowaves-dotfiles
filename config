## Configuration file for CAVA.
# intended to be used at minimum font size

[general]

live-config = 1
mode = normal
framerate = 60
sensitivity = 200

bars = 0
bar_width = 0
bar_spacing = 0

[input]

method = portaudio
source = auto

[output]

method = noncurses
orientation = top

[color]

background = default
gradient = 1
gradient_count = 8
gradient_color_1 = '#555555'
gradient_color_2 = '#888888'
gradient_color_3 = '#ffffff'
gradient_color_4 = '#ffffff'
gradient_color_5 = '#ffffff'
gradient_color_6 = '#ffffff'
gradient_color_7 = '#ffffff'
gradient_color_8 = '#ffffff'

[smoothing]

monstercat = 1
waves = 0
noise_reduction = 10
